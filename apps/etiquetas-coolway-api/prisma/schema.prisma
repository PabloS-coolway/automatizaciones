generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Maestro de referencias Coolway (fuente de verdad de los códigos de barra).
/// Una fila por SKU = (ref, size). Solo la app escribe; los consumidores leen.
model Reference {
  id           Int      @id @default(autoincrement())
  style        String
  color        String
  ref          String
  size         String
  sku          String
  ean13        String?  @unique
  upc          String?
  colorNameWeb String?  @map("color_name_web")
  season       String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([ref, size]) // un SKU por talla de cada referencia
  @@index([style, color])
  @@map("reference")
}

/// Roles de acceso: operador (genera etiquetas, lee el maestro) y admin (además importa al maestro).
enum Role {
  operador
  admin
}

/// Usuarios internos de la herramienta. Alta/baja por un admin (no hay registro abierto).
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         Role     @default(operador)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("app_user")
}
