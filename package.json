{
  "name": "yorga-automatizaciones",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo de automatizaciones del Grupo Yorga.",
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "npm install && npm run db:up && npm run db:generate && npm run db:migrate",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "db:up": "docker compose up -d && until docker exec yorga-coolway-db pg_isready -U coolway >/dev/null 2>&1; do sleep 1; done",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "npm run prisma:generate -w @yorga/etiquetas-coolway-api",
    "db:migrate": "npm run prisma:deploy -w @yorga/etiquetas-coolway-api",
    "db:migrate:new": "npm run prisma:migrate -w @yorga/etiquetas-coolway-api",
    "db:studio": "npm run prisma:studio -w @yorga/etiquetas-coolway-api",
    "maestro:import:demo": "npm run maestro:import:demo -w @yorga/etiquetas-coolway-api"
  },
  "devDependencies": {
    "turbo": "^2.1.0"
  }
}
